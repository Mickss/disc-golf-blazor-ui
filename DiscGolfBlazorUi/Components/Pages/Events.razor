@page "/events"
@inject DiscGolfService EventService

<h3>Upcoming Disc Golf Events</h3>

@if (events == null)
{
    <p>Loading events...</p>
}
else
{
    <table class="table-events">
        <thead>
            <tr>
                <th>ID</th>
                <th>PDGA</th>
                <th>Title</th>
                <th>Region</th>
                <th>Registration</th>
                <th>Vacancies</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in events)
            {
                <tr>
                    <td>@ev.Id</td>
                    <td>@ev.Pdga</td>
                    <td>@ev.TournamentTitle</td>
                    <td>@ev.Region</td>
                    <td>@ev.Registration</td>
                    <td>@ev.Vacancies</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<DiscGolfEvent>? events;

    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetEventsAsync();
    }
}